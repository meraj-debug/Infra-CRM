# ---- Inframantra CRM backend (Render) ----
# Copy to .env locally; set the same keys in Render → Environment.
# NEVER commit a filled-in .env.

NODE_ENV=production
PORT=4000

# --- Database -----------------------------------------------------------------
# MongoDB Atlas connection string. Keep the real value out of source control.
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.hrmulmx.mongodb.net/inframantra?retryWrites=true&w=majority"

# --- Auth ---------------------------------------------------------------------
# Long random string. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

# --- Access + refresh tokens (Module 1.3) -------------------------------------
# ACCESS token (sent as Authorization: Bearer). 12h keeps the wrapped legacy app
# working; the React client silently refreshes on 401 regardless of lifetime.
ACCESS_EXPIRES_IN=12h
# Long-lived REFRESH token, stored in an httpOnly cookie the browser sends back.
REFRESH_EXPIRES_IN=7d
# Separate secret for refresh tokens. Generate another: openssl rand -hex 32
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
# Password-reset link lifetime (Module 1.2). 10 minutes as required.
RESET_EXPIRES_IN=10m

# Refresh-cookie flags. In production (https + cross-site frontend) BOTH must be
# on: COOKIE_SECURE=true and COOKIE_SAMESITE=none. For local dev leave unset and
# the defaults (secure=false, samesite=lax) work on http://localhost.
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none

# Shared key the browser sends as `x-workspace-key` to read/write CRM state.
# Must match window.CRM_WORKSPACE_KEY in the frontend's config.js.
# Leave EMPTY only for local dev — empty means the state store is public.
WORKSPACE_KEY=

# --- Frontend / CORS ----------------------------------------------------------
# The deployed frontend URL.
FRONTEND_URL=https://imcrm.netlify.app

# Every origin allowed to call this API (comma-separated, no trailing slashes).
# Include FRONTEND_URL, any Netlify deploy-preview domain, and local dev ports.
CORS_ORIGINS=https://imcrm.netlify.app,http://localhost:5173,http://localhost:3000,http://127.0.0.1:5500

# --- Behaviour ----------------------------------------------------------------
# Run the idempotent seed on every boot. Safe to leave on.
SEED_ON_BOOT=true
# Max request body. CRM snapshots carry activity photos, so 1mb is not enough.
JSON_LIMIT=25mb

# --- Optional -----------------------------------------------------------------
SENTRY_DSN=

# --- Outbound mail (password resets) ------------------------------------------
# Gmail / Google Workspace needs an APP PASSWORD, not the account password:
#   Google Account -> Security -> 2-Step Verification -> App passwords
# Without these, POST /api/users/:username/reset-password refuses (503) rather
# than changing a password nobody can be told.
SMTP_USER=you@yourdomain.com
APP_PASSWORD_EMAIL=xxxx xxxx xxxx xxxx
SMTP_HOST=smtp.gmail.com
# 587 (STARTTLS) is more firewall/ISP-friendly than 465 (implicit TLS).
SMTP_PORT=587
SMTP_FROM=Inframantra CRM <you@yourdomain.com>

# --- Cloudinary (asset uploads) -----------------------------------------------
# Powers image/file uploads (project media, booking docs, photos). The API
# secret signs uploads server-side and NEVER goes to the browser. cloud_name is
# public — it appears in every asset URL (res.cloudinary.com/<cloud_name>/...).
# Find all three at the top of your Cloudinary dashboard.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=your-api-secret
