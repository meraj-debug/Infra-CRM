# ---- Inframantra CRM backend (Render) ----
# Copy to .env locally, or set these in Render → Environment. Never commit real values.

NODE_ENV=production
PORT=4000

# MongoDB Atlas. Put the REAL connection string here (with a ROTATED password),
# not in source. Format:
# mongodb+srv://merajvarid007_db_user:r1F8un50VhIbYJBU@cluster0.hrmulmx.mongodb.net/inframantra?retryWrites=true&w=majority
MONGODB_URI="mongodb+srv://merajvarid007_db_user:r1F8un50VhIbYJBU@cluster0.hrmulmx.mongodb.net/inframantra?retryWrites=true&w=majority"

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

# Comma-separated allowed origins (your Netlify site + local dev)
CORS_ORIGINS=https://your-site.netlify.app,http://localhost:5173

# Error tracking (optional)
SENTRY_DSN=
